# =============================================================================
# Fintelligence Docker Environment Variables
# Copy this file and fill in your actual values before running docker compose.
# Usage: docker compose --env-file .env.docker up -d
# =============================================================================

# ---- Database ----
DB_PASSWORD=change_me_to_a_strong_password

# ---- Redis ----
REDIS_PASSWORD=change_me_to_a_strong_redis_password

# ---- JWT Authentication ----
JWT_SECRET=change_me_to_a_random_string_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_to_another_random_string_at_least_32_chars

# ---- Anthropic AI ----
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ---- External Market Data APIs ----
COINGECKO_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYMARKET_API_KEY=

# ---- Frontend URLs ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
