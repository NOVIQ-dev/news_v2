generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  displayName     String?
  avatarUrl       String?
  language        String    @default("en")
  theme           String    @default("dark")
  dashboardLayout Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  portfolios    Portfolio[]
  alerts        Alert[]
  aiChats       AiChat[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  name      String
  assetType String
  amount    Float
  buyPrice  Float
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
}

model Alert {
  id            String    @id @default(cuid())
  userId        String
  type          String
  condition     Json
  message       String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiChat {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NewsCache {
  id          String   @id @default(cuid())
  hash        String   @unique
  title       String
  summary     String?
  content     String?
  url         String
  source      String
  region      String
  tags        String[]
  language    String
  imageUrl    String?
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([hash])
  @@index([publishedAt])
}

model EconomicEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  country     String
  importance  String
  datetime    DateTime
  actual      String?
  forecast    String?
  previous    String?
  createdAt   DateTime @default(now())

  @@index([datetime])
}
